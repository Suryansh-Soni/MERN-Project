<% layout("/layouts/boilerplate.ejs") %>

<div class="row mt-4 mb-5">
  <div class="col-md-10 offset-md-1 col-lg-8 offset-lg-2">
    <div class="card listing-card-show shadow border-0 rounded-4">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="listing_image"
      />

      <div class="card-body p-4">
        <h2 class="card-title mb-3"><%= listing.title %></h2>

        <p class="card-text text-muted"><%= listing.description %></p>

        <hr />

        <p class="card-text">
          <strong>Price:</strong>
          &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
        </p>

        <p class="card-text">
          <strong>Location:</strong>
          <%= listing.location %>, <%= listing.country %>
        </p>

        <div class="d-flex gap-3 mt-4">
          <a
            href="/listings/<%= listing._id %>/edit"
            class="btn btn-dark px-4 rounded-3"
          >
            Edit
          </a>

          <form
            action="/listings/<%= listing._id %>?_method=DELETE"
            method="POST"
          >
            <button type="submit" class="btn btn-danger px-4 rounded-3">
              Delete
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
