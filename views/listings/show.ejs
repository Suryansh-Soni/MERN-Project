<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wanderlust</title>
  </head>
  <body>
    <h3>Listing details:</h3>
    <ul>
      <li><%= listing.title %></li>
      <li><%= listing.description %></li>
      <li>Price: &#8377; <%= listing.price.toLocaleString("en-IN") %></li>
      <li>Location: <%= listing.location %></li>
    </ul>
    <br>
    <a href="/listings/<%= listing._id %>/edit">Edit this listing</a>
    <br><br><form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
      <button type="submit">Delete this listing</button>
    </form>
  </body>
</html>
